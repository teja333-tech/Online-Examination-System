import javax.swing.;
import java.awt.;
import java.awt.event.;
import java.sql.;
import java.util.*;

// Student class
class Student {
int id;
String name;
Student(int id, String name) {
this.id = id;
this.name = name;
}
}

// Main OnlineExam class
public class OnlineExam extends JFrame implements ActionListener {
private Connection conn;
private Statement stmt;
private ResultSet rs;
private JLabel questionLabel;
private JRadioButton[] options;
private ButtonGroup group;
private JButton nextButton, registerButton;
private int currentQuestion = 0;
private int score = 0;
private java.util.List<String> questions = new ArrayList<>();
private java.util.List<String[]> answers = new ArrayList<>();
private java.util.List<Integer> correctAnswers = new ArrayList<>();
private Student currentStudent;

public OnlineExam() {  
    try {  
        conn = DriverManager.getConnection("jdbc:mysql://localhost:3306/examdb", "root", "");  
        stmt = conn.createStatement();  
    } catch (Exception e) {  
        e.printStackTrace();  
    }  

    setTitle("Online Exam System");  
    setLayout(new BorderLayout());  

    questionLabel = new JLabel("Question will appear here");  
    add(questionLabel, BorderLayout.NORTH);  

    JPanel centerPanel = new JPanel(new GridLayout(4, 1));  
    options = new JRadioButton[4];  
    group = new ButtonGroup();  
    for (int i = 0; i < 4; i++) {  
        options[i] = new JRadioButton();  
        group.add(options[i]);  
        centerPanel.add(options[i]);  
    }  
    add(centerPanel, BorderLayout.CENTER);  

    JPanel bottomPanel = new JPanel(new FlowLayout());  
    nextButton = new JButton("Next");  
    nextButton.addActionListener(this);  
    bottomPanel.add(nextButton);  

    registerButton = new JButton("Register");  
    registerButton.addActionListener(this);  
    bottomPanel.add(registerButton);  

    add(bottomPanel, BorderLayout.SOUTH);  

    setSize(500, 300);  
    setDefaultCloseOperation(EXIT_ON_CLOSE);  
    setVisible(true);  

    loadQuestions();  
}  

private void loadQuestions() {  
    try {  
        rs = stmt.executeQuery("SELECT * FROM questions");  
        while (rs.next()) {  
            questions.add(rs.getString("question_text"));  
            String[] opts = new String[4];  
            opts[0] = rs.getString("option_a");  
            opts[1] = rs.getString("option_b");  
            opts[2] = rs.getString("option_c");  
            opts[3] = rs.getString("option_d");  
            answers.add(opts);  
            correctAnswers.add(rs.getInt("correct_option"));  
        }  
        showQuestion(0);  
    } catch (Exception e) {  
        e.printStackTrace();  
    }  
}  

private void showQuestion(int index) {  
    questionLabel.setText(questions.get(index));  
    String[] opts = answers.get(index);  
    for (int i = 0; i < 4; i++) {  
        options[i].setText(opts[i]);  
        options[i].setSelected(false);  
    }  
}  

private int getSelectedOption() {  
    for (int i = 0; i < 4; i++) {  
        if (options[i].isSelected()) return i;  
    }  
    return -1;  
}  

public void actionPerformed(ActionEvent e) {  
    if (e.getSource() == registerButton) {  
        String name = JOptionPane.showInputDialog(this, "Enter your name:");  
        int id = Integer.parseInt(JOptionPane.showInputDialog(this, "Enter your ID:"));  
        currentStudent = new Student(id, name);  
        JOptionPane.showMessageDialog(this, "Registered successfully as " + name);  
    }  

    if (e.getSource() == nextButton) {  
        int selected = getSelectedOption();  
        if (selected == -1) {  
            JOptionPane.showMessageDialog(this, "Please select an option");  
            return;  
        }  

        if (selected == correctAnswers.get(currentQuestion)) {  
            score++;  
        }  

        currentQuestion++;  
        if (currentQuestion < questions.size()) {  
            showQuestion(currentQuestion);  
        } else {  
            JOptionPane.showMessageDialog(this, "Exam finished! Your score: " + score);  
            saveResult();  
            dispose();  
        }  
    }  
}  

private void saveResult() {  
    try {  
        PreparedStatement ps = conn.prepareStatement("INSERT INTO results(student_name, score) VALUES (?, ?)");  
        ps.setString(1, currentStudent.name);  
        ps.setInt(2, score);  
        ps.executeUpdate();  
    } catch (Exception e) {  
        e.printStackTrace();  
    }  
}  

public static void main(String[] args) {  
    new OnlineExam();  
}

}
